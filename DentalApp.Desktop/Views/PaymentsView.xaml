<UserControl x:Class="DentalApp.Desktop.Views.PaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="20" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ödeme ve İndirim Yönetimi" 
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                   Foreground="{StaticResource BulkaDarkBlue}"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignFilledTabControl}">
            <!-- 1. İndirim Anlaşmaları / Anlaşmalı Kurumlar -->
            <TabItem Header="Anlaşmalı Kurumlar">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Sol Panel: Kurum Listesi -->
                    <materialDesign:Card Grid.Column="0" Padding="20" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Anlaşmalı Kurumlar" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Yenile" 
                                       Command="{Binding LoadAgreementsCommand}"
                                       Style="{StaticResource MaterialDesignFlatButton}"
                                       ToolTip="Kurum listesini yeniden yükle"/>
                            </Grid>
                            
                            <!-- Admin için yeni anlaşma ekleme bölümü -->
                            <ScrollViewer Grid.Row="1"
                                        MaxHeight="400"
                                        VerticalScrollBarVisibility="Auto"
                                        Margin="0,0,0,15"
                                        Visibility="{Binding CanViewPrices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Yeni İndirim Anlaşması" 
                                             Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                             Foreground="{StaticResource BulkaDarkBlue}"
                                             FontWeight="Bold"
                                             Margin="0,0,0,10"/>
                                    
                                    <TextBox Text="{Binding NewAgreementName, UpdateSourceTrigger=PropertyChanged}" 
                                           materialDesign:HintAssist.Hint="Kurum Adı *" 
                                           Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                           Margin="0,0,0,15"/>
                                    
                                    <TextBlock Text="Kategori Bazlı İndirimler" 
                                             Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                             Foreground="{StaticResource BulkaDarkBlue}"
                                             FontWeight="Bold"
                                             Margin="0,0,0,10"/>
                                    
                                    <ItemsControl ItemsSource="{Binding CategoryDiscounts}" Margin="0,0,0,15">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding CategoryName}" 
                                                             VerticalAlignment="Center"
                                                             Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                             Margin="0,0,10,0"/>
                                                    <TextBox Grid.Column="1"
                                                           Text="{Binding DiscountPercentage, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F1}'}" 
                                                           materialDesign:HintAssist.Hint="İndirim %" 
                                                           Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <Button Content="Kaydet" 
                                          Command="{Binding AddAgreementCommand}"
                                          Style="{StaticResource MaterialDesignRaisedButton}"
                                          Background="{StaticResource BulkaMediumBlue}"
                                          Foreground="White"
                                          HorizontalAlignment="Right"
                                          Width="120"
                                          Margin="0,10,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                            
                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock Text="Henüz anlaşma yok veya liste yüklenemedi. &#x0a;Yenile'yi deneyin veya yukarıdan yeni anlaşma ekleyin."
                                         Visibility="{Binding IsAgreementsListEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Style="{StaticResource MaterialDesignBody1TextBlock}"
                                         Foreground="Gray"
                                         TextWrapping="Wrap"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Margin="20"/>
                                <DataGrid ItemsSource="{Binding InstitutionAgreements}"
                                    SelectedItem="{Binding SelectedAgreement}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    IsReadOnly="True"
                                    SelectionMode="Single"
                                    SelectionUnit="FullRow"
                                    GridLinesVisibility="Horizontal"
                                    Style="{StaticResource MaterialDesignDataGrid}"
                                    Visibility="{Binding IsAgreementsListEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#BBDEFB"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kurum Adı" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Ortalama İndirim" Binding="{Binding AverageDiscountPercentage, StringFormat='{}{0:F1}%'}" Width="*"/>
                                    <DataGridTemplateColumn Header="İşlemler" Width="Auto"
                                                          Visibility="{Binding DataContext.CanViewPrices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Düzenle" 
                                                      Command="{Binding DataContext.EditAgreementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"
                                                      Style="{StaticResource MaterialDesignFlatButton}"
                                                      Margin="5,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                    
                    <!-- Sağ Panel: Kurum Detayları (Kategori Bazlı İndirimler) -->
                    <materialDesign:Card Grid.Column="2" Padding="20" Background="White">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Kurum Detayları" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,15"
                                         Visibility="{Binding SelectedAgreement, Converter={StaticResource NullToBooleanConverter}}"/>
                                
                                <TextBlock Text="Kurum seçin" 
                                         Style="{StaticResource MaterialDesignBody1TextBlock}"
                                         Foreground="Gray"
                                         Margin="0,20,0,0"
                                         Visibility="{Binding SelectedAgreement, Converter={StaticResource InverseBooleanConverter}}"/>
                                
                                <TextBlock Text="{Binding SelectedAgreement.Name, StringFormat='Kurum: {0}'}" 
                                         Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,15"
                                         Visibility="{Binding SelectedAgreement, Converter={StaticResource NullToBooleanConverter}}"/>
                                
                                <TextBlock Text="Kategori Bazlı İndirim Oranları" 
                                         Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         Margin="0,0,0,10"
                                         Visibility="{Binding SelectedAgreement, Converter={StaticResource NullToBooleanConverter}}"/>
                                
                                <DataGrid ItemsSource="{Binding SelectedAgreementCategoryDiscounts}"
                                         AutoGenerateColumns="False"
                                         CanUserAddRows="False"
                                         IsReadOnly="True"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="Horizontal"
                                         Style="{StaticResource MaterialDesignDataGrid}"
                                         MaxHeight="400"
                                         Visibility="{Binding SelectedAgreement, Converter={StaticResource NullToBooleanConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryName}" Width="*"/>
                                        <DataGridTextColumn Header="İndirim" Binding="{Binding DiscountPercentage, StringFormat='{}{0:F1}%'}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource BulkaMediumBlue}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <TextBlock Text="Bu kurum için kategori bazlı indirim tanımlanmamış." 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}"
                                         Foreground="Gray"
                                         Margin="0,20,0,0"
                                         TextAlignment="Center"
                                         Visibility="{Binding HasCategoryDiscounts, Converter={StaticResource InverseBooleanConverter}}"/>
                                
                                <!-- Secretary için read-only uyarı -->
                                <TextBlock Text="Not: Sekreter kullanıcıları anlaşmaları sadece görüntüleyebilir, düzenleyemez." 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                         Foreground="Gray"
                                         TextWrapping="Wrap"
                                         Margin="0,15,0,0"
                                         Visibility="{Binding IsSecretary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            
            <!-- 2. Tedavi Planı Onaylama (Sadece Sekreter) -->
            <TabItem Header="Tedavi Planı Onaylama"
                    Visibility="{Binding IsSecretary, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <materialDesign:Card Grid.Row="0" Padding="20" Margin="0,0,0,20" Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Onay Bekleyen Tedavi Planları" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,10"/>
                                <TextBlock Text="Seçilen Planların Toplam Maliyeti:" 
                                         Style="{StaticResource MaterialDesignBody1TextBlock}"
                                         FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedPlansTotal, StringFormat='{}{0:F2} ₺'}" 
                                         Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,5,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Planları Yükle" 
                                      Command="{Binding LoadPendingPlansCommand}"
                                      Style="{StaticResource MaterialDesignRaisedButton}"
                                      Background="{StaticResource BulkaMediumBlue}"
                                      Foreground="White"
                                      Margin="0,0,10,0"
                                      Width="150"/>
                                <Button Content="Onayla" 
                                      Command="{Binding ApprovePlansCommand}"
                                      Style="{StaticResource MaterialDesignRaisedButton}"
                                      Background="{StaticResource BulkaMediumBlue}"
                                      Foreground="White"
                                      Width="150"
                                      Height="40"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                    
                    <materialDesign:Card Grid.Row="1" Padding="20" Background="White">
                        <DataGrid ItemsSource="{Binding PendingTreatmentPlans}" 
                                SelectedItem="{Binding SelectedPlan}"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                IsReadOnly="True"
                                Style="{StaticResource MaterialDesignDataGrid}"
                                RowDetailsVisibilityMode="VisibleWhenSelected">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Seç" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                    Checked="CheckBox_Checked"
                                                    Unchecked="CheckBox_Unchecked"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Hasta" Binding="{Binding PatientName}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Diş Hekimi" Binding="{Binding DentistName}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="İşlemler" Binding="{Binding ProceduresCount, StringFormat='{}{0} işlem'}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Toplam Maliyet" 
                                                 Binding="{Binding TotalCost, StringFormat='{}{0:F2} ₺'}" 
                                                 Width="*"
                                                 IsReadOnly="True"
                                                 Visibility="{Binding DataContext.CanViewPrices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </DataGrid.Columns>
                            <DataGrid.RowDetailsTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Margin="20,10" Padding="15" Background="{StaticResource BulkaLightBlue}">
                                        <StackPanel>
                                            <TextBlock Text="İşlem Detayları" 
                                                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                                     Foreground="{StaticResource BulkaDarkBlue}"
                                                     FontWeight="Bold"
                                                     Margin="0,0,0,10"/>
                                            <DataGrid ItemsSource="{Binding Procedures}" 
                                                    AutoGenerateColumns="False"
                                                    CanUserAddRows="False"
                                                    IsReadOnly="True"
                                                    HeadersVisibility="Column"
                                                    Style="{StaticResource MaterialDesignDataGrid}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="Auto"/>
                                                    <DataGridTextColumn Header="İşlem Adı" Binding="{Binding Name}" Width="*"/>
                                                    <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="Auto"/>
                                                    <DataGridTextColumn Header="Fiyat" 
                                                                     Binding="{Binding Price, StringFormat='{}{0:F2} ₺'}" 
                                                                     Width="Auto"
                                                                     Visibility="{Binding DataContext.CanViewPrices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </DataGrid.RowDetailsTemplate>
                        </DataGrid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            
            <!-- 3. Ödeme Alma -->
            <TabItem Header="Ödeme Alma">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Sol Panel: Ödeme Formu -->
                    <materialDesign:Card Grid.Column="0" Padding="20" Background="White">
                        <StackPanel>
                            <TextBlock Text="Ödeme İşlemi" 
                                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,0,0,20"/>
                            
                            <ComboBox ItemsSource="{Binding Patients}"
                                    SelectedItem="{Binding SelectedPaymentPatient}"
                                    DisplayMemberPath="FullName"
                                    materialDesign:HintAssist.Hint="Hasta Seçin *"
                                    IsEditable="False"
                                    Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Planlanan İşlemler" 
                                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,10,0,10"
                                     Visibility="{Binding SelectedPaymentPatient, Converter={StaticResource InverseBooleanConverter}}"/>
                            
                            <DataGrid ItemsSource="{Binding PatientTreatmentPlans}"
                                    SelectedItem="{Binding SelectedPatientTreatmentPlan}"
                                    AutoGenerateColumns="False"
                                    CanUserAddRows="False"
                                    IsReadOnly="True"
                                    MaxHeight="200"
                                    Margin="0,0,0,15"
                                    Visibility="{Binding SelectedPaymentPatient, Converter={StaticResource InverseBooleanConverter}}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Seç" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="İşlem" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Fiyat" 
                                                     Binding="{Binding Price, StringFormat='{}{0:F2} ₺'}" 
                                                     Width="Auto"
                                                     Visibility="{Binding DataContext.CanViewPrices, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <TextBlock Text="Toplam Maliyet:" 
                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                     Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedPaymentPatientTotal, StringFormat='{}{0:F2} ₺'}" 
                                     Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,0,0,20"/>
                            
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                    SelectedItem="{Binding SelectedPaymentMethod}"
                                    materialDesign:HintAssist.Hint="Ödeme Şekli *"
                                    IsEditable="False"
                                    Margin="0,0,0,15"/>
                            
                            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Alınan Miktar (₺) *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,15"/>
                            
                            <Button Content="Ödeme İşle" 
                                  Command="{Binding ProcessPaymentCommand}"
                                  Style="{StaticResource MaterialDesignRaisedButton}"
                                  Background="{StaticResource BulkaMediumBlue}"
                                  Foreground="White"
                                  Width="150"
                                  Height="40"/>
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <!-- Sağ Panel: Bilgiler -->
                    <materialDesign:Card Grid.Column="2" Padding="20" Background="White">
                        <StackPanel>
                            <TextBlock Text="Bilgiler" 
                                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,0,0,20"/>
                            
                            <materialDesign:Card Padding="15" Background="{StaticResource BulkaLightBlue}" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Kalan Borç:" 
                                             Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                    <TextBlock Text="{Binding RemainingDebt, StringFormat='{}{0:F2} ₺'}" 
                                             Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                             Foreground="{StaticResource BulkaDarkBlue}"
                                             FontWeight="Bold"
                                             Margin="0,5,0,0"/>
                                </StackPanel>
                            </materialDesign:Card>
                            
                            <materialDesign:Card Padding="15" Background="{StaticResource BulkaLightBlue}">
                                <StackPanel>
                                    <TextBlock Text="Hekimin Ciro Payı:" 
                                             Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                    <TextBlock Text="{Binding DentistCommission, StringFormat='{}{0:F2} ₺'}" 
                                             Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                             Foreground="{StaticResource BulkaDarkBlue}"
                                             FontWeight="Bold"
                                             Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding DentistCommissionPercentage, StringFormat='(Ciro Payı: {0:F2}%)'}" 
                                             Style="{StaticResource MaterialDesignBody2TextBlock}"
                                             Foreground="{StaticResource BulkaMediumBlue}"
                                             Margin="0,5,0,0"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            
            <!-- 4. Gelir Gider -->
            <TabItem Header="Gelir Gider">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Üst Panel: Özet Bilgiler -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Alacaklar -->
                        <materialDesign:Card Grid.Column="0" Padding="20" Background="White">
                            <StackPanel>
                                <TextBlock Text="Toplam Alacaklar" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding TotalReceivables, StringFormat='{}{0:F2} ₺'}" 
                                         Style="{StaticResource MaterialDesignHeadline3TextBlock}"
                                         Foreground="{StaticResource BulkaMediumBlue}"
                                         FontWeight="Bold"/>
                                <TextBlock Text="Henüz ödenmemiş toplam borç" 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}"
                                         Foreground="Gray"
                                         Margin="0,5,0,0"/>
                            </StackPanel>
                        </materialDesign:Card>
                        
                        <!-- Gelir -->
                        <materialDesign:Card Grid.Column="2" Padding="20" Background="White">
                            <StackPanel>
                                <TextBlock Text="Toplam Gelir" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:F2} ₺'}" 
                                         Style="{StaticResource MaterialDesignHeadline3TextBlock}"
                                         Foreground="{StaticResource BulkaMediumBlue}"
                                         FontWeight="Bold"/>
                                <TextBlock Text="Alınan toplam ödeme" 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}"
                                         Foreground="Gray"
                                         Margin="0,5,0,0"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                    
                    <!-- Alt Panel: Hasta Seçimi ve Detaylar -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Sol Panel: Hasta Seçimi ve Borç Bilgileri -->
                        <materialDesign:Card Grid.Column="0" Padding="20" Background="White">
                            <StackPanel>
                                <TextBlock Text="Hasta Seçimi" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,15"/>
                                
                                <ComboBox ItemsSource="{Binding Patients}"
                                        SelectedItem="{Binding SelectedIncomePatient}"
                                        DisplayMemberPath="FullName"
                                        materialDesign:HintAssist.Hint="Hasta Seçin"
                                        IsEditable="False"
                                        Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Borç Bilgileri" 
                                         Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,10"
                                         Visibility="{Binding SelectedIncomePatient, Converter={StaticResource NullToBooleanConverter}}"/>
                                
                                <materialDesign:Card Padding="15" Background="{StaticResource BulkaLightBlue}" 
                                                   Margin="0,0,0,10"
                                                   Visibility="{Binding SelectedIncomePatient, Converter={StaticResource NullToBooleanConverter}}">
                                    <StackPanel>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Toplam Borç:" Grid.Column="0" 
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                            <TextBlock Text="{Binding SelectedPatientTotalDebt, StringFormat='{}{0:F2} ₺'}" 
                                                     Grid.Column="1"
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource BulkaDarkBlue}"/>
                                        </Grid>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Ödenen:" Grid.Column="0" 
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                            <TextBlock Text="{Binding SelectedPatientPaidAmount, StringFormat='{}{0:F2} ₺'}" 
                                                     Grid.Column="1"
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                     FontWeight="Bold"
                                                     Foreground="Green"/>
                                        </Grid>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Kalan Borç:" Grid.Column="0" 
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                     FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedPatientRemainingDebt, StringFormat='{}{0:F2} ₺'}" 
                                                     Grid.Column="1"
                                                     Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                     FontWeight="Bold"
                                                     Foreground="Red"/>
                                        </Grid>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                        </materialDesign:Card>
                        
                        <!-- Sağ Panel: Ödeme Geçmişi -->
                        <materialDesign:Card Grid.Column="2" Padding="20" Background="White">
                            <StackPanel>
                                <TextBlock Text="Ödeme Geçmişi" 
                                         Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         Margin="0,0,0,15"
                                         Visibility="{Binding SelectedIncomePatient, Converter={StaticResource NullToBooleanConverter}}"/>
                                
                                <TextBlock Text="Hasta seçin" 
                                         Style="{StaticResource MaterialDesignBody1TextBlock}"
                                         Foreground="Gray"
                                         Margin="0,20,0,0"
                                         Visibility="{Binding SelectedIncomePatient, Converter={StaticResource InverseBooleanConverter}}"/>
                                
                                <DataGrid ItemsSource="{Binding SelectedPatientPayments}"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="False"
                                        IsReadOnly="True"
                                        MaxHeight="400"
                                        Style="{StaticResource MaterialDesignDataGrid}"
                                        Visibility="{Binding SelectedIncomePatient, Converter={StaticResource NullToBooleanConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tarih" 
                                                         Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" 
                                                         Width="*"/>
                                        <DataGridTextColumn Header="Miktar" 
                                                         Binding="{Binding Amount, StringFormat='{}{0:F2} ₺'}" 
                                                         Width="*"/>
                                        <DataGridTextColumn Header="Yöntem" 
                                                         Binding="{Binding PaymentMethod}" 
                                                         Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <ProgressBar Grid.Row="1" Style="{StaticResource MaterialDesignCircularProgressBar}" 
                     IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="60"/>
    </Grid>
</UserControl>