<UserControl x:Class="DentalApp.Desktop.Views.AppointmentDetailsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <materialDesign:Card Padding="30" MaxWidth="500">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Randevu Detayları" 
                          Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                          Foreground="{StaticResource BulkaDarkBlue}"
                          FontWeight="Bold"/>
                <Separator Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <StackPanel>
                    <!-- Hasta Bilgileri -->
                    <TextBlock Text="Hasta Bilgileri" 
                              Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                              Foreground="{StaticResource BulkaMediumBlue}"
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Hasta Adı:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="1" Text="{Binding Appointment.PatientFullName}" Margin="0,0,0,8"/>
                    </Grid>

                    <!-- Randevu Bilgileri -->
                    <TextBlock Text="Randevu Bilgileri" 
                              Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                              Foreground="{StaticResource BulkaMediumBlue}"
                              FontWeight="Bold"
                              Margin="0,10,0,10"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tarih:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Appointment.AppointmentDate, StringFormat='{}{0:dd.MM.yyyy}'}" Margin="0,0,0,8"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Başlangıç Saati:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Appointment.StartTime, StringFormat='{}{0:hh\\:mm}'}" Margin="0,0,0,8"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Bitiş Saati:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Appointment.EndTime, StringFormat='{}{0:hh\\:mm}'}" Margin="0,0,0,8"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="İşlem Tipi:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Appointment.AppointmentType}" Margin="0,0,0,8"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Durum:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StatusDisplay}" Margin="0,0,0,8"/>
                    </Grid>

                    <!-- Doktor Bilgisi -->
                    <TextBlock Text="Doktor" 
                              Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                              Foreground="{StaticResource BulkaMediumBlue}"
                              FontWeight="Bold"
                              Margin="0,10,0,10"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Doktor:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Grid.Column="1" Text="{Binding Appointment.DentistEmail}" Margin="0,0,0,8"/>
                    </Grid>

                    <!-- Notlar -->
                    <TextBlock Text="Notlar" 
                              Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                              Foreground="{StaticResource BulkaMediumBlue}"
                              FontWeight="Bold"
                              Margin="0,10,0,10"
                              Visibility="{Binding HasNotes, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <TextBlock Text="{Binding Appointment.Notes}" 
                              TextWrapping="Wrap"
                              Margin="0,0,0,15"
                              Visibility="{Binding HasNotes, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <TextBox Text="{Binding CancellationReason, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="İptal sebebi (opsiyonel)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,10,0,5"
                             IsEnabled="{Binding CanCancel}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="İPTAL ET"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#C62828"
                        BorderBrush="#C62828"
                        Margin="0,0,10,0"
                        Width="120"/>
                <Button Content="DÜZENLE" 
                       Command="{Binding EditCommand}" 
                       Style="{StaticResource MaterialDesignOutlinedButton}"
                       Margin="0,0,10,0"
                       Width="120"/>
                <Button Content="KAPAT" 
                       Command="{Binding CloseCommand}" 
                       Style="{StaticResource MaterialDesignRaisedButton}"
                       Background="{StaticResource BulkaMediumBlue}"
                       Foreground="White"
                       Width="120"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
