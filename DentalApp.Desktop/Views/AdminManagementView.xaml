<UserControl x:Class="DentalApp.Desktop.Views.AdminManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="20" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Kullanıcı Yönetimi" 
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                   Foreground="{StaticResource BulkaDarkBlue}"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="380"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.8*" MinWidth="650"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sol Panel: Kullanıcı Ekleme Formu -->
            <materialDesign:Card Grid.Column="0" Padding="30" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Kullanıcı Türü Seçimi - İyileştirilmiş -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Kullanıcı Türü Seçin" 
                             Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                             Foreground="{StaticResource BulkaDarkBlue}"
                             FontWeight="Bold"
                             Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:Card Grid.Column="0" Margin="3" Height="72"
                                           Background="{Binding IsDentistSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#E3F2FD|White'}"
                                           BorderBrush="{Binding IsDentistSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#1976D2|#E0E0E0'}"
                                           BorderThickness="2"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="DentistCard_MouseLeftButtonDown">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Doctor" Width="22" Height="22"
                                                       Foreground="{StaticResource BulkaMediumBlue}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                <TextBlock Text="Doktor"
                                         FontSize="14"
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="1" Margin="3" Height="72"
                                           Background="{Binding IsSecretarySelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#E8F5E9|White'}"
                                           BorderBrush="{Binding IsSecretarySelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#388E3C|#E0E0E0'}"
                                           BorderThickness="2"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="SecretaryCard_MouseLeftButtonDown">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountTie" Width="22" Height="22"
                                                       Foreground="#2E7D32"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                <TextBlock Text="Sekreter"
                                         FontSize="14"
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Margin="3" Height="72"
                                           Background="{Binding IsPatronSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#FFF3E0|White'}"
                                           BorderBrush="{Binding IsPatronSelected, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='#F57C00|#E0E0E0'}"
                                           BorderThickness="2"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="PatronCard_MouseLeftButtonDown">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountStar" Width="22" Height="22"
                                                       Foreground="#FF9800"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"/>
                                <TextBlock Text="Patron"
                                         FontSize="14"
                                         Foreground="{StaticResource BulkaDarkBlue}"
                                         FontWeight="Bold"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </StackPanel>
                
                    <!-- Doktor Formu -->
                    <StackPanel Grid.Row="2" 
                            Visibility="{Binding IsDentistSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <TextBlock Text="Doktor Bilgileri" 
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding User.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Ad *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Soyad *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.TCNo, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="TC No *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.Phone, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Telefon *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.University, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Mezun Olduğu Üniversite *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <DatePicker SelectedDate="{Binding User.DiplomaDate}" 
                                           materialDesign:HintAssist.Hint="Diploma Tarihi *"
                                           Language="tr-TR"
                                           Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.DiplomaNo, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Diploma No *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBox Text="{Binding User.Address, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Adres" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       TextWrapping="Wrap"
                                       AcceptsReturn="True"
                                       MinHeight="60"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.IBAN, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="IBAN" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.Salary, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Maaş (TRY)" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.CommissionRate, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Ciro Yüzdesi (%)" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <TextBox Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" 
                                       materialDesign:HintAssist.Hint="Kullanıcı Adı (E-posta) *" 
                                       Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                       Margin="0,0,0,10"/>
                                
                                <PasswordBox x:Name="DentistPasswordBox"
                                           materialDesign:HintAssist.Hint="Parola *" 
                                           Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                           PasswordChanged="PasswordBox_PasswordChanged"
                                           Margin="0,0,0,10"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Uzmanlık Grid -->
                        <TextBlock Text="Uzmanlık" 
                                 Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                 Margin="0,15,0,10"/>
                        <UniformGrid Columns="3" Margin="0,10,0,20">
                            <CheckBox Content="Diş Tabibi" 
                                    IsChecked="{Binding Specializations[0], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Ağız-Diş-Çene Cerrahisi" 
                                    IsChecked="{Binding Specializations[1], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Radyoloji" 
                                    IsChecked="{Binding Specializations[2], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Endodonti" 
                                    IsChecked="{Binding Specializations[3], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Ortodonti" 
                                    IsChecked="{Binding Specializations[4], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Pedodonti" 
                                    IsChecked="{Binding Specializations[5], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Periodontoloji" 
                                    IsChecked="{Binding Specializations[6], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Protetik" 
                                    IsChecked="{Binding Specializations[7], Mode=TwoWay}"
                                    Margin="5"/>
                            <CheckBox Content="Restoratif" 
                                    IsChecked="{Binding Specializations[8], Mode=TwoWay}"
                                    Margin="5"/>
                        </UniformGrid>
                    </StackPanel>
                    
                    <!-- Sekreter Formu -->
                    <Grid Grid.Row="2"
                            Visibility="{Binding IsSecretarySelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sekreter Bilgileri" 
                                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,0,0,15"/>
                            
                            <TextBox Text="{Binding User.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Ad *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Soyad *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.TCNo, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="TC No *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Phone, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Telefon *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBox Text="{Binding User.Address, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Adres" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   TextWrapping="Wrap"
                                   AcceptsReturn="True"
                                   MinHeight="60"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.IBAN, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="IBAN" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Salary, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Maaş (TRY)" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Kullanıcı Adı (E-posta) *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <PasswordBox x:Name="SecretaryPasswordBox"
                                       materialDesign:HintAssist.Hint="Parola *" 
                                       Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                       PasswordChanged="PasswordBox_PasswordChanged"
                                       Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Patron Formu -->
                    <Grid Grid.Row="2"
                            Visibility="{Binding IsPatronSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Patron Bilgileri" 
                                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                     Foreground="{StaticResource BulkaDarkBlue}"
                                     FontWeight="Bold"
                                     Margin="0,0,0,15"/>
                            
                            <TextBox Text="{Binding User.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Ad *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Soyad *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Phone, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Telefon *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBox Text="{Binding User.TCNo, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="TC No (Opsiyonel)" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Address, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Adres (Opsiyonel)" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   TextWrapping="Wrap"
                                   AcceptsReturn="True"
                                   MinHeight="60"
                                   Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}" 
                                   materialDesign:HintAssist.Hint="Kullanıcı Adı (E-posta) *" 
                                   Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                   Margin="0,0,0,10"/>
                            
                            <PasswordBox x:Name="PatronPasswordBox"
                                       materialDesign:HintAssist.Hint="Parola *" 
                                       Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                       PasswordChanged="PasswordBox_PasswordChanged"
                                       Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Kaydet Butonu -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="İPTAL" 
                              Command="{Binding CancelCommand}" 
                              Style="{StaticResource MaterialDesignOutlinedButton}"
                              Margin="0,0,10,0"
                              Width="120"/>
                        <Button Content="KAYDET" 
                              Command="{Binding SaveCommand}" 
                              Style="{StaticResource MaterialDesignRaisedButton}"
                              Background="{StaticResource BulkaMediumBlue}"
                              Foreground="White"
                              materialDesign:ButtonProgressAssist.IsIndeterminate="{Binding IsBusy}"
                              materialDesign:ButtonProgressAssist.IsIndicatorVisible="{Binding IsBusy}"
                              Width="120"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </materialDesign:Card>
        
        <!-- Sağ Panel: Mevcut Kullanıcılar Listesi -->
        <materialDesign:Card Grid.Column="2" Padding="20" Background="White" MinWidth="650">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="280"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Mevcut Kullanıcılar"
                             Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                             Foreground="{StaticResource BulkaDarkBlue}"
                             FontWeight="Bold"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Yenile"
                          Command="{Binding LoadUsersCommand}"
                          Style="{StaticResource MaterialDesignFlatButton}"
                          Margin="0,0,0,0"/>
                </Grid>

                <materialDesign:Card Grid.Row="1" Padding="12" Margin="0,0,0,15" Background="#EFF6FF"
                                    Visibility="{Binding IsEditingUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Kullanıcıyı Düzenle" FontWeight="Bold" Margin="0,0,0,8"
                                 Foreground="{StaticResource BulkaDarkBlue}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditUserEmail, UpdateSourceTrigger=PropertyChanged}"
                                   materialDesign:HintAssist.Hint="E-posta"
                                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                   Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1" SelectedValue="{Binding EditUserRole}"
                                    SelectedValuePath="Tag"
                                    materialDesign:HintAssist.Hint="Rol">
                                <ComboBoxItem Content="Diş Hekimi" Tag="dentist"/>
                                <ComboBoxItem Content="Sekreter" Tag="secretary"/>
                                <ComboBoxItem Content="Patron" Tag="admin"/>
                            </ComboBox>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Vazgeç" Command="{Binding CancelUserEditCommand}"
                                  Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0"/>
                            <Button Content="Kaydet" Command="{Binding SaveUserEditCommand}"
                                  Style="{StaticResource MaterialDesignRaisedButton}"
                                  Background="{StaticResource BulkaMediumBlue}" Foreground="White" Width="110"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <DataGrid Grid.Row="2"
                        ItemsSource="{Binding Users}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        SelectionMode="Single"
                        SelectionUnit="FullRow"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        RowHeight="36"
                        MinHeight="260"
                        Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="1.3*" MinWidth="110"/>
                        <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="1.7*" MinWidth="150"/>
                        <DataGridTextColumn Header="Rol" Binding="{Binding RoleDisplay}" Width="0.8*" MinWidth="75"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="1*" MinWidth="95"/>
                        <DataGridTextColumn Header="TC No" Binding="{Binding TCNo}" Width="1*" MinWidth="90"/>
                        <DataGridTextColumn Header="Kayıt" Binding="{Binding CreatedAtDisplay}" Width="0.9*" MinWidth="85"/>
                        <DataGridTextColumn Header="Son Giriş" Binding="{Binding LastLoginAtDisplay}" Width="0.9*" MinWidth="85"/>
                        <DataGridCheckBoxColumn Header="E-posta ✓" Binding="{Binding EmailVerified}" Width="Auto" MinWidth="70"/>
                        <DataGridTemplateColumn Header="İşlemler" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource MaterialDesignIconButton}"
                                               ToolTip="Düzenle">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource MaterialDesignIconButton}"
                                               ToolTip="Sil"
                                               Foreground="#DC2626">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
        </Grid>

        <ProgressBar Grid.Row="1" Style="{StaticResource MaterialDesignCircularProgressBar}" 
                     IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="60"/>
    </Grid>
</UserControl>