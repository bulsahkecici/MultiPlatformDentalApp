<UserControl x:Class="DentalApp.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="20" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Kontrol Paneli" 
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                       Foreground="{StaticResource BulkaDarkBlue}"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>
            <Button Command="{Binding RefreshCommand}" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Foreground="{StaticResource BulkaMediumBlue}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,5,0" Foreground="{StaticResource BulkaMediumBlue}"/>
                    <TextBlock Text="YENİLE" Foreground="{StaticResource BulkaMediumBlue}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- PATRON DASHBOARD -->
        <Grid Grid.Row="1" Visibility="{Binding IsPatron, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Toplam Tutar ve Ödenen Tutar -->
            <UniformGrid Grid.Row="0" Columns="2" Rows="1" Margin="0,0,0,20">
                <materialDesign:Card Margin="10" Padding="20" Background="White">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CurrencyUsd" 
                                               Width="48" 
                                               Height="48" 
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,10"
                                               Foreground="{StaticResource BulkaMediumBlue}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} ₺'}" 
                                 Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="Toplam Tutar" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="10" Padding="20" Background="White">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                               Width="48" 
                                               Height="48" 
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,10"
                                               Foreground="{StaticResource BulkaLightGreen}"/>
                        <TextBlock Text="{Binding PaidAmount, StringFormat='{}{0:N2} ₺'}" 
                                 Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="Ödenen Tutar" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding PaidPercentage, Mode=OneWay}" 
                                   Maximum="100"
                                   Height="8"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource BulkaLightGreen}"/>
                        <TextBlock Text="{Binding PaidPercentage, Mode=OneWay, StringFormat='{}{0:F1}%'}" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"
                                 Margin="0,5,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>
            
            <!-- Doktorların Ciroları -->
            <materialDesign:Card Grid.Row="1" Margin="10" Padding="20" Background="White">
                <StackPanel>
                    <TextBlock Text="Doktorların Ciroları" 
                             Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                             Foreground="{StaticResource BulkaDarkBlue}"
                             FontWeight="Bold"
                             Margin="0,0,0,15"/>
                    <DataGrid ItemsSource="{Binding DentistTurnovers}" 
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Doktor Adı" Binding="{Binding DentistName}" Width="*"/>
                            <DataGridTextColumn Header="Ciro" Binding="{Binding Turnover, StringFormat='{}{0:N2} ₺'}" Width="*"/>
                            <DataGridTextColumn Header="Ciro Payı (%)" Binding="{Binding TurnoverPercentage, StringFormat='{}{0:F2}%'}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- SEKRETER DASHBOARD -->
        <Grid Grid.Row="1" Visibility="{Binding IsSecretary, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sol Panel: Yaklaşan Randevular (Bugün ve Yarın) -->
            <materialDesign:Card Grid.Column="0" Padding="15" Background="White">
                <StackPanel>
                    <TextBlock Text="Yaklaşan Randevular (Bugün &amp; Yarın)" 
                             Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                             Foreground="{StaticResource BulkaDarkBlue}"
                             FontWeight="Bold"
                             Margin="0,0,0,15"/>
                    <TextBlock Text="Sadece bugün ve yarınki randevular gösterilmektedir." 
                             Style="{StaticResource MaterialDesignBody2TextBlock}" 
                             Foreground="Gray"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"/>
                    <ListView ItemsSource="{Binding UpcomingAppointmentsList}"
                             MaxHeight="500"
                             Padding="0,0,4,0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,4,12" Padding="12" CornerRadius="8"
                                        Background="{Binding AppointmentDate, Converter={StaticResource DateToColorConverter}}"
                                        BorderBrush="{StaticResource InkBorder}" BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="AppointmentCard_MouseLeftButtonDown">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="2" Background="{StaticResource BulkaMediumBlue}" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding AppointmentDateTime, StringFormat='{}{0:dddd, dd MMMM yyyy HH:mm}', ConverterCulture='tr-TR'}"
                                                     FontSize="13"
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource InkPrimary}"
                                                     TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding PatientFullName}"
                                                     FontSize="15"
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource BulkaDarkBlue}"
                                                     TextWrapping="Wrap"
                                                     Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding DentistDisplayName, StringFormat='Doktor: {0}'}"
                                                     FontSize="12"
                                                     Foreground="{StaticResource InkSecondary}"
                                                     TextTrimming="CharacterEllipsis"
                                                     ToolTip="{Binding DentistDisplayName}"
                                                     Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding AppointmentType, Converter={StaticResource AppointmentTypeToTurkishConverter}, StringFormat='Tip: {0}'}"
                                                     FontSize="12"
                                                     Foreground="{StaticResource InkMuted}"
                                                     Margin="0,2,0,0"
                                                     Visibility="{Binding AppointmentType, Converter={StaticResource ObjectToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </materialDesign:Card>
            
            <!-- Sağ Panel: Saat + Takvim + İstatistikler -->
            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <materialDesign:Card Padding="20" Background="White" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:HH:mm:ss}'}" 
                                 Style="{StaticResource MaterialDesignHeadline2TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 x:Name="ClockTextBlock"/>
                        <TextBlock Text="{Binding CurrentDate, StringFormat='{}{0:dddd, dd MMMM yyyy}', ConverterCulture='tr-TR'}" 
                                 Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"
                                 Margin="0,10,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
                
                <materialDesign:Card Padding="15" Background="White" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Hızlı Erişim"
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="56"/>
                                <RowDefinition Height="56"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Margin="3"
                                    Command="{Binding DataContext.NavigateToAppointmentsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Calendar" Width="20" Height="20" Margin="0,0,6,0" Foreground="{StaticResource BulkaMediumBlue}"/>
                                    <TextBlock Text="Randevu" Foreground="{StaticResource BulkaDarkBlue}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="0" Grid.Column="1" Margin="3"
                                    Command="{Binding DataContext.NavigateToPatientsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Account" Width="20" Height="20" Margin="0,0,6,0" Foreground="{StaticResource BulkaMediumBlue}"/>
                                    <TextBlock Text="Hasta" Foreground="{StaticResource BulkaDarkBlue}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="0" Margin="3"
                                    Command="{Binding DataContext.NavigateToPaymentsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Cash" Width="20" Height="20" Margin="0,0,6,0" Foreground="{StaticResource BulkaMediumBlue}"/>
                                    <TextBlock Text="Finans" Foreground="{StaticResource BulkaDarkBlue}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="1" Margin="3"
                                    Command="{Binding DataContext.NavigateToInstitutionAgreementsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Domain" Width="20" Height="20" Margin="0,0,6,0" Foreground="{StaticResource BulkaMediumBlue}"/>
                                    <TextBlock Text="Kurum" Foreground="{StaticResource BulkaDarkBlue}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="20" Background="White">
                    <StackPanel>
                        <TextBlock Text="Bugünkü İstatistikler"
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,15"/>
                        <UniformGrid Columns="2" Rows="2">
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding TodayAppointments, StringFormat='{}{0}'}" 
                                         Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                         Foreground="{StaticResource BulkaMediumBlue}"
                                         FontWeight="Bold"
                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Bugünkü Randevu" 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                         Foreground="Gray"
                                         HorizontalAlignment="Center"
                                         TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding TotalPatients, StringFormat='{}{0}'}" 
                                         Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                         Foreground="{StaticResource BulkaMediumBlue}"
                                         FontWeight="Bold"
                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Toplam Hasta" 
                                         Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                         Foreground="Gray"
                                         HorizontalAlignment="Center"
                                         TextWrapping="Wrap"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
        
        <!-- DENTIST DASHBOARD (Same as Secretary but without clock/calendar) -->
        <Grid Grid.Row="1" Visibility="{Binding IsDentist, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sol Panel: Yaklaşan Randevular -->
            <materialDesign:Card Grid.Column="0" Padding="15" Background="White">
                <StackPanel>
                    <TextBlock Text="Yaklaşan Randevular" 
                             Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                             Foreground="{StaticResource BulkaDarkBlue}"
                             FontWeight="Bold"
                             Margin="0,0,0,15"/>
                    <ListView ItemsSource="{Binding UpcomingAppointmentsList}"
                             MaxHeight="500"
                             Padding="0,0,4,0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,4,12" Padding="12" CornerRadius="8"
                                        Background="White"
                                        BorderBrush="{StaticResource InkBorder}" BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="AppointmentCard_MouseLeftButtonDown">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="2" Background="{StaticResource BulkaMediumBlue}" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding AppointmentDateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                     FontSize="13"
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource InkPrimary}"/>
                                            <TextBlock Text="{Binding PatientFullName}"
                                                     FontSize="15"
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource BulkaDarkBlue}"
                                                     Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding DentistDisplayName, StringFormat='Doktor: {0}'}"
                                                     FontSize="12"
                                                     Foreground="{StaticResource InkSecondary}"
                                                     TextTrimming="CharacterEllipsis"
                                                     ToolTip="{Binding DentistDisplayName}"
                                                     Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </materialDesign:Card>
            
            <!-- Sağ Panel: İstatistikler ve Bilgiler -->
            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <materialDesign:Card Padding="20" Background="White" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Bugünkü Randevular" 
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TodayAppointments, StringFormat='Toplam: {0}'}" 
                                 Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"
                                 Margin="0,10,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
                
                <materialDesign:Card Padding="20" Background="White" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Bu Ay Yapılan Tedaviler" 
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TotalTreatments, StringFormat='Toplam: {0}'}" 
                                 Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 HorizontalAlignment="Center"
                                 Margin="0,10,0,0"/>
                    </StackPanel>
                </materialDesign:Card>
                
                <materialDesign:Card Padding="20" Background="White">
                    <StackPanel>
                        <TextBlock Text="Hızlı Erişim" 
                                 Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                 Foreground="{StaticResource BulkaDarkBlue}"
                                 FontWeight="Bold"
                                 Margin="0,0,0,15"/>
                        <TextBlock Text="• Yeni tedavi eklemek için Tedaviler menüsünü kullanın" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 Margin="0,5,0,5"/>
                        <TextBlock Text="• Randevularınızı görüntülemek için Randevular menüsünü kullanın" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 Margin="0,5,0,5"/>
                        <TextBlock Text="• Hasta bilgilerini görmek için Hastalar menüsünü kullanın" 
                                 Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                 Foreground="{StaticResource BulkaMediumBlue}"
                                 Margin="0,5,0,5"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="1" Style="{StaticResource MaterialDesignCircularProgressBar}" 
                     IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="60"/>
    </Grid>
</UserControl>