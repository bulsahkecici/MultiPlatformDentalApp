<Window x:Class="DentalApp.Desktop.Views.AgreementEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Kurum Anlaşmasını Düzenle" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <materialDesign:Card Padding="24" Width="460">
        <StackPanel>
            <TextBlock Text="Kurum Anlaşmasını Düzenle" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBox Text="{Binding InstitutionName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Kurum adı" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12"/>
            <TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="İletişim kişisi" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12"/>
            <TextBox Text="{Binding ContactPhone, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Telefon" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12"/>
            <TextBox Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="E-posta" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12"/>
            <TextBox Text="{Binding DiscountPercentage, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Genel indirim (%)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,12"/>
            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Notlar" Style="{StaticResource MaterialDesignFloatingHintTextBox}" AcceptsReturn="True" MinHeight="70" Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="VAZGEÇ" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
                <Button Content="KAYDET" IsDefault="True" Click="Save_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </StackPanel>
    </materialDesign:Card>
</Window>
