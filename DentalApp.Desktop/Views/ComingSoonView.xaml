<UserControl x:Class="DentalApp.Desktop.Views.ComingSoonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="20" Background="Transparent">
        <materialDesign:Card Padding="40" Background="White" MaxWidth="640" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <Border Background="{StaticResource BulkaLightBlue}"
                        CornerRadius="50"
                        Width="100"
                        Height="100"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24">
                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                             Width="48"
                                             Height="48"
                                             Foreground="{StaticResource BulkaMediumBlue}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <Border Background="#FFF3E0"
                        CornerRadius="12"
                        Padding="10,4"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="Yakında"
                               Foreground="#F57C00"
                               FontWeight="SemiBold"/>
                </Border>

                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                           Foreground="{StaticResource BulkaDarkBlue}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{Binding Description}"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           Foreground="{StaticResource BulkaMediumBlue}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="480"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Bu özellik bir sonraki sürümde kullanıma sunulacaktır."
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="Gray"
                           TextAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
