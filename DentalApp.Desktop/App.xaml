<Application x:Class="DentalApp.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DentalApp.Desktop"
             xmlns:helpers="clr-namespace:DentalApp.Desktop.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- BULKA DENTAL "Aqua Mint" Paleti: Teal (Primary), Nane (Secondary), Mercan (Accent) -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Pink" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- BULKA DENTAL "Aqua Mint" Renk Paleti -->
            <SolidColorBrush x:Key="BulkaLightBlue" Color="#CCFBF1"/>
            <SolidColorBrush x:Key="BulkaMediumBlue" Color="#0D9488"/>
            <SolidColorBrush x:Key="BulkaDarkBlue" Color="#134E4A"/>
            <SolidColorBrush x:Key="BulkaSilver" Color="#94A3B8"/>
            <SolidColorBrush x:Key="BulkaLightGreen" Color="#4ADE80"/>
            <SolidColorBrush x:Key="BulkaGradientStart" Color="#F0FDFA"/>
            <SolidColorBrush x:Key="BulkaGradientEnd" Color="#FFFFFF"/>

            <!-- Yeni: Nane (ikincil) ve Mercan (vurgu) — Aqua Mint paletinin tamamlayıcıları -->
            <SolidColorBrush x:Key="MintBrush" Color="#5EEAD4"/>
            <SolidColorBrush x:Key="MintSurface" Color="#F0FDFA"/>
            <SolidColorBrush x:Key="CoralAccent" Color="#FB7185"/>
            <SolidColorBrush x:Key="CoralAccentDark" Color="#E11D48"/>

            <!-- Nötr metin/yüzey tonları (web tarafındaki ink/surface token ölçeğiyle aynı) -->
            <SolidColorBrush x:Key="InkPrimary" Color="#0F172A"/>
            <SolidColorBrush x:Key="InkSecondary" Color="#334155"/>
            <SolidColorBrush x:Key="InkMuted" Color="#64748B"/>
            <SolidColorBrush x:Key="InkBorder" Color="#E2E8F0"/>
            <SolidColorBrush x:Key="SurfaceMuted" Color="#F8FAFC"/>
            <SolidColorBrush x:Key="PageBackground" Color="#F1F5F9"/>

            <!-- Durum renkleri (web tarafındaki success/warn/danger tonlarıyla aynı) -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
            <SolidColorBrush x:Key="WarnBrush" Color="#D97706"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>

            <!-- Gradient Brush -->
            <LinearGradientBrush x:Key="BulkaGradientBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F0FDFA" Offset="0"/>
                <GradientStop Color="#FFFFFF" Offset="0.5"/>
                <GradientStop Color="#F0FDFA" Offset="1"/>
            </LinearGradientBrush>

            <!-- Global Converters -->
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <helpers:StatusToTurkishConverter x:Key="StatusToTurkishConverter"/>
            <helpers:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
            <helpers:ToothNumberEqualityConverter x:Key="ToothNumberEqualityConverter"/>
            <helpers:ToothInCollectionConverter x:Key="ToothInCollectionConverter"/>
            <helpers:DateToColorConverter x:Key="DateToColorConverter"/>
            <helpers:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
            <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <helpers:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
            <helpers:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter"/>
            <helpers:ObjectToCollapsedConverter x:Key="ObjectToCollapsedConverter"/>
            <helpers:AppointmentTypeToTurkishConverter x:Key="AppointmentTypeToTurkishConverter"/>
            <helpers:GenderToTurkishConverter x:Key="GenderToTurkishConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- Global DatePicker Style for Turkish -->
            <Style TargetType="DatePicker">
                <Setter Property="Language" Value="tr-TR"/>
            </Style>

            <!-- Sayfa başlığı (her view'ın en üstündeki "Kontrol Paneli" / "Hasta Yönetimi" vb.) -->
            <Style x:Key="PageTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource BulkaDarkBlue}"/>
            </Style>

            <!-- Boş liste mesajı (ör. "Henüz randevu yok") -->
            <Style x:Key="EmptyStateText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource InkMuted}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="20"/>
            </Style>

            <!-- Şekil dili: Aqua Mint'in "çok yuvarlak" hissi — kartlar 16px, butonlar pill'e yakın.
                 CardAssist/ButtonAssist var olan kontrol şablonunun okuduğu ekli özellikler
                 olduğu için şablonu değiştirmeden (güvenle) tüm uygulamaya uygulanır. -->
            <Style TargetType="materialDesign:Card">
                <Setter Property="UniformCornerRadius" Value="16"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="18"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
