# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
# Reverse proxy aynı makinedeyse loopback kullanın. Docker/ağ proxy'sinde
# yalnızca gerçek proxy IP/CIDR'lerini virgülle ayırarak yazın; `true` kullanmayın.
TRUST_PROXY=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dentalappdb
DB_USER=dentaluser
DB_PASS=StrongPass123!
DB_SSL=false
# DB_SSL=true olduğunda üretimde mutlaka true kalmalıdır.
DB_SSL_REJECT_UNAUTHORIZED=true

# Security
JWT_SECRET=dev-secret
# Opsiyonel: refresh token'lar için ayrı secret. Boş bırakılırsa JWT_SECRET
# kullanılır (token'lar yine de tokenType claim'i ile ayrıştırılır) — üretimde
# ayrı bir güçlü secret tanımlamanız önerilir.
JWT_REFRESH_SECRET=
# Klinik belge ve MFA sırlarının AES-256-GCM şifrelemesi için en az 32
# karakterlik, rastgele ve yedeklerden ayrı saklanan anahtar.
DATA_ENCRYPTION_KEY=development-data-encryption-key-change-me
# Veritabanı yedekleri için DATA_ENCRYPTION_KEY'den farklı, en az 32
# karakterlik ayrı anahtar kullanın ve uygulama sunucusu dışında saklayın.
BACKUP_ENCRYPTION_KEY=development-backup-encryption-key-change-me
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
DOCUMENT_STORAGE_DIR=data/patient-documents
DOCUMENT_MAX_BYTES=20971520
# Production varsayılanı admin,dentist. Kademeli geçişte önce kullanıcıları
# kaydedin, ardından bu rolleri zorunlu kılın.
MFA_REQUIRED_ROLES=admin,dentist
# Virgülle ayrılmış izinli origin listesi (Angular dev sunucusu 4200 portunda çalışır)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Account Lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Password Policy
PASSWORD_MIN_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true
PASSWORD_HISTORY_COUNT=3

# Email Service (for verification and password reset)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@dentalapp.com

# Admin Seed User
ADMIN_EMAIL=admin@mail.com
ADMIN_PASSWORD=Admin@123456

# Business Rules
# Bu orandan yüksek manuel indirim talepleri sekreter tarafından doğrudan
# uygulanamaz, patron onayı bekler (bkz. POST /api/payments/approvals/:id/approve)
HIGH_DISCOUNT_THRESHOLD_PERCENT=20
